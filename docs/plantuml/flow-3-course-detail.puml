@startuml
title Luong 3 - Xem chi tiet khoa hoc

participant "Nhan vien hoc vu" as User
participant "CourseController" as Ctrl
participant "CourseService" as Svc
participant "CourseRepository" as Repo
participant "Course Detail View" as View

User -> Ctrl : GET /course/detail/IELTS-6.5
Ctrl -> Svc : getCourseByCode("IELTS-6.5")
Svc -> Repo : findByCode("IELTS-6.5")
Repo --> Svc : Course
Svc --> Ctrl : Course
Ctrl --> View : model.addAttribute("course", course)
View --> User : Hien thi mo ta, giang vien, thoi luong

@enduml
